<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LabelPlus_Next.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:u="https://irihi.tech/ursa"
        Width="1200" Height="650"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="650"
        x:Class="LabelPlus_Next.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="LabelPlus_Next">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
    <!-- Main Grid with proper row definitions -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            
        </Grid.RowDefinitions>

      
        <u:ToolBar Grid.Row="0" Margin="0 10 0 0">
             <Button Content="File(_F)">
                 <Button.Flyout>
                     <MenuFlyout>
                         <MenuItem Header="New(_N)"   />
                         <MenuItem Header="-"/>
                         <MenuItem Header="Open(_O)" />
                         <MenuItem Header="-"/>
                         <MenuItem Header="Save(_S)" />
                         <MenuItem Header="-"/>
                         <MenuItem Header="Save As(_A)" />
                         <MenuItem Header="-"/>
                         <MenuItem Header="Exit(_E)" />
                     </MenuFlyout>

                 </Button.Flyout>
             </Button>

                <Button Content="Image Manager(_I)" Click="Imagine_manager_OnClick"></Button>
                <Button Content="Output(_P)" >
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuItem Header="Output All Images" Click="Output_OnClick"></MenuItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
           <Button Content="Help(_H)">
               <Button.Flyout>
                   <MenuFlyout>
                       <MenuItem Header="View Help(_H)"  Click="View_Help_OnClick"/>
                       <MenuItem Header="-"/>
                       <MenuItem Header="About(_A)" Click="About_OnClick" />
                   </MenuFlyout>
              </Button.Flyout>
            </Button>
            
             
            
                <TextBlock  Text="Language:" HorizontalAlignment="Left" FontSize="16" Margin="30 3.5 0 0"></TextBlock>
           <ComboBox Name="LangComboBox" ItemsSource="{Binding LangList}"
                     Margin="10 0 0 0 " SelectedItem="{Binding CurrentLang}" MinWidth="100"></ComboBox>
            <u:ThemeToggleButton Margin="50 0 0 0" ></u:ThemeToggleButton>
            
        </u:ToolBar>

        <!-- Tool Bar -->
        <u:ToolBar Grid.Row="1">
            <u:ToolBar>
                <Button Content="Browse Mode" />
                <Button Content="Edit Label Mode" />
                <Button Content="Input Mode" />
                <Button Content="Check Mode" />
                
                
                
            </u:ToolBar>
            <u:ButtonGroup Margin="200 0 0 0">
                <Button  Content="Zoom In"/>
                <Button  Content="Zoom Out"/>
            </u:ButtonGroup>
            
             
            
        </u:ToolBar>

        <!-- Main Content -->
        
    </Grid>
</Window>